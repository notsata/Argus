{
  "name": "argus",
  "version": "1.1.3",
  "description": "Argus — live portfolio tracking dashboard",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis",
    "publish": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.argus.portfolio",
    "productName": "Argus",
    "copyright": "Argus",
    "directories": {
      "output": "dist-electron"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "notsata",
        "repo": "Argus",
        "private": false
      }
    ],
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/.bin",
      "!**/node_modules/nodemon/**",
      "!**/node_modules/pkg/**",
      "!**/node_modules/electron-builder/**",
      "!**/node_modules/electron/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Argus Installer ${version}.exe"
    },
    "portable": {
      "artifactName": "Argus Portable.exe"
    }
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "nodemon": "^3.1.9"
  }
}
